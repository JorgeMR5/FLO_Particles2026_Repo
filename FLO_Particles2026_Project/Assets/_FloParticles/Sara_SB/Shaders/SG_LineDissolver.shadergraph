{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "05d4b67e6ccc4498a91a620d047fced9",
    "m_Title": "",
    "m_Content": "La resta combina ruido local con gradiente global:\nEl gradiente define el “punto base” del dissolve (desde abajo hacia arriba).\nEl ruido añade variación alrededor de ese punto, para que no sea uniforme.\nResultado: un dissolve que sube de abajo hacia arriba, pero con bordes irregulares y orgánicos.\n\nEJEMPLO:\nSin resta → todo el dissolve sería solo ruido → no sabrías dónde empieza\nSin ruido → dissolve sería una línea recta perfecta\nCon la resta → el objeto se disuelve de abajo hacia arriba, pero con formas aleatorias naturales\n",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -2932.800048828125,
        "y": 441.5999755859375,
        "width": 318.400146484375,
        "height": 271.20001220703127
    },
    "m_Group": {
        "m_Id": ""
    }
}

