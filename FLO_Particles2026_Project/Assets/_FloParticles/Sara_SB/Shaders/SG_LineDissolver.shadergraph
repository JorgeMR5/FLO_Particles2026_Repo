{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "9335671bc9254da8a97545641264ae87",
    "m_Title": "",
    "m_Content": "Step2 controla el final del borde del dissolve\nAl sumar GlowWidth, está diciendo:\n“Haz visible un poquito más allá del límite del dissolve principal para crear un borde”\nAsí, Step1 corta el inicio del dissolve, y Step2 corta el final del borde\nLa región entre Step1 y Step2 se usa para aplicar glow / efecto brillante",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -2024.800048828125,
