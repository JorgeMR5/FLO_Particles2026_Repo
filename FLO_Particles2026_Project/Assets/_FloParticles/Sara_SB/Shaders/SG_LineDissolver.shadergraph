    "m_Content": "El noise (por sí solo) da valores entre 0 y 1. Multiplicarlo por la posición del objeto espacializa el ruido, haciendo que el efecto siga la forma del objeto. Así, el dissolve parece “envolver” el objeto en lugar de ser solo un patrón plano\n",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -3808.0,
        "y": 938.3999633789063,
        "width": 200.0,
        "height": 152.0
    },
    "m_Group": {
        "m_Id": ""
    }
}

